<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="script.bingie.settings" name="Bingie Settings" version="1.0.1" provider-name="YourName">
    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.script" library="default.py">
        <provides>executable</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">Standalone Bingie Settings Menu</summary>
        <description lang="en_GB">Launches the Bingie skin settings window as a standalone app.</description>
        <platform>all</platform>
    </extension>
</addon>
